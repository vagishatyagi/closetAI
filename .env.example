# -----------------------------------------------------------------------------
# Google Hackathon AI Wardrobe Assistant - Environment Variables Template
# Copy this file to .env.local and fill in your keys. Do NOT commit .env.local.
# -----------------------------------------------------------------------------

# Supabase Configurations (Database & Storage)
# Get these from your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google AI Studio / Gemini API Key
# Put the Tier 3 Hackathon API Key here.
GEMINI_API_KEY=AIzaSy...

# OpenWeatherMap API Key (For daily weather analysis)
# Get a free key from https://home.openweathermap.org/api_keys
WEATHER_API_KEY=your_openweather_api_key_here

# Clerk / Google OAuth Configurations (For Authentication & Google Calendar scopes)
# Retrieve these credentials from your Clerk Dashboard or Google Cloud Console (OAuth 2.0 Client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Resend API Key (For daily styling email newsletters)
# Create a free account at https://resend.com
RESEND_API_KEY=re_your_resend_api_key
CRON_SECRET=your_super_secret_cron_token_for_vercel_triggers
